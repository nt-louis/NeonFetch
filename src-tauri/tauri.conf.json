{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NeonFetch",
  "version": "0.0.3",
  "identifier": "com.neonfetch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cargo build --manifest-path src-tauri/Cargo.toml && npm run vite:dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NeonFetch",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "../public/logo.ico"
    ],
    "linux": {
      "appimage": {
        "files": {}
      }
    },
    "windows": {
      "allowDowngrades": true,
      "wix": {
        "language": "en-US"
      }
    }
  }
}
